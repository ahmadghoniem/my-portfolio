---
import { getCollection, getEntry, render } from "astro:content"
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import Layout from "../../layouts/Layout.astro"
import TechBadge from "../../components/TechBadge.astro"
import IconArrowRight from "../../components/icons/IconArrowRight.astro"
import IconArrowUpRight from "../../components/icons/IconArrowUpRight.astro"

export const prerender = true

export async function getStaticPaths() {
  const projects = await getCollection("projects")
  return projects.map((project) => ({
    params: { slug: project.id }
  }))
}

const { slug } = Astro.params
const project = await getEntry("projects", slug)

if (!project) {
  return Astro.redirect("/404")
}

const { Content } = await render(project)

const { title, description, overview, tags, video, image, github, ctas, quote, citation, socialProof } = project.data

// Import project assets
const projectAssets = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*/*", { eager: true })
const projectImage = image && slug ? projectAssets[`/src/assets/projects/${slug}/${image}`] : null
const projectVideo = video && slug ? projectAssets[`/src/assets/projects/${slug}/${video}`] : null

// Filter out internal "Read more" CTAs � we're already on the page
const externalCtas = ctas?.filter((cta) => !cta.href.startsWith("/")) ?? []
const primaryCta = externalCtas[0]

// Next project
const allProjects = await getCollection("projects")
const sorted = allProjects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
const currentIndex = sorted.findIndex((p) => p.id === slug)
const nextProject = sorted[currentIndex + 1] ?? null
---

<Layout title={`${title} | Ahmad Ghoniem`}>
  <article class="px-4 pt-28 pb-16 sm:px-6 sm:pt-32 sm:pb-24">
    <div class="mx-auto w-full max-w-4xl">
      <!-- Title + CTAs -->
      <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <h1 class="font-display text-display text-4xl font-semibold sm:text-5xl md:text-6xl">
          {title}
        </h1>
        <div class="flex shrink-0 flex-wrap items-center gap-3">
          {
            primaryCta && (
              <a
                href={primaryCta.href}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-foreground text-background inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-opacity hover:opacity-80">
                {primaryCta.label}
                <IconArrowUpRight class="size-3.5" />
              </a>
            )
          }
          {
            github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="border-border text-foreground hover:bg-surface inline-flex items-center gap-1.5 rounded-full border px-4 py-2 text-sm font-medium transition-colors">
                Source code
                <IconArrowUpRight class="size-3.5" />
              </a>
            )
          }
        </div>
      </div>

      <!-- Overview -->
      <p class="text-muted mb-6 text-base leading-relaxed sm:text-lg">
        {overview ?? description}
      </p>

      <!-- Tech badges with icons -->
      <div class="mb-12 flex flex-wrap gap-2">
        {tags.map((tag: string) => <TechBadge tag={tag} />)}
      </div>

      <!-- Video / image -->
      {
        (video || image) && (
          <div class="border-border bg-surface mb-12 overflow-hidden rounded-2xl border">
            {video && projectVideo ? (
              <video autoplay muted loop playsinline class="w-full object-cover">
                <source src={projectVideo.default} type="video/webm" />
              </video>
            ) : projectImage ? (
              <Image src={projectImage.default} alt={`${title} in action`} class="w-full object-cover" />
            ) : null}
          </div>
        )
      }

      <!-- Prose: story paragraph + technical callouts -->
      <div class="project-content">
        <Content />
      </div>

      <!-- Divider -->
      <hr class="border-border my-12" />

      <!-- Quote -->
      {
        quote && (
          <figure class="mb-8">
            <blockquote class="border-accent-border border-l-2 pl-5">
              <p class="text-foreground text-base leading-relaxed sm:text-lg">&ldquo;{quote}&rdquo;</p>
            </blockquote>
            {citation && <figcaption class="text-muted mt-3 pl-5 text-sm">&mdash; {citation}</figcaption>}
          </figure>
        )
      }

      <!-- Reddit / social proof screenshots -->
      {
        socialProof && socialProof.length > 0 && (
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {socialProof.map((src: string) => (
              <div class="border-border bg-surface overflow-hidden rounded-xl border">
                <img src={`/images/projects/social/${src}`} alt="Community feedback" class="w-full object-cover" />
              </div>
            ))}
          </div>
        )
      }

      <!-- Next project -->
      {
        nextProject && (
          <div class="border-border mt-16 flex items-center justify-end border-t pt-8">
            <a
              href={`/projects/${nextProject.id}`}
              class="text-muted hover:text-foreground group flex items-center gap-2 text-sm font-medium transition-colors duration-200">
              Next: {nextProject.data.title}
              <IconArrowRight class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
          </div>
        )
      }
    </div>
  </article>
</Layout>

<style is:global>
  .project-content p {
    font-family: var(--font-body);
    color: var(--color-foreground);
    font-size: 1rem;
    line-height: 1.625;
    margin-bottom: 1.25rem;
    max-width: 65ch;
  }

  .project-content h2 {
    font-family: var(--font-ui);
    color: var(--color-display);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .project-content h3 {
    font-family: var(--font-ui);
    color: var(--color-foreground);
    font-size: 1.0625rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.375rem;
  }

  .project-content code {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    font-size: 0.875em;
    padding: 0.125rem 0.375rem;
  }

  .project-content p:has(img),
  .project-content img {
    max-width: var(--container-4xl);
  }

  @media (min-width: 640px) {
    .project-content p {
      font-size: 1.125rem;
    }

    .project-content h2 {
      font-size: 1.375rem;
    }
  }
</style>
