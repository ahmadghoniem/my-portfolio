---
import IconSpotify from "./icons/IconSpotify.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"
---

<div
  id="sw-card"
  class="group/card relative flex w-xs max-w-sm items-center gap-2.5 overflow-hidden rounded-lg p-1 pr-3 text-white lg:w-sm">
  <!-- Cover Art -->
  <div
    id="sw-art-wrap"
    class="group-hover/card:glow-shadow-40 size-16.5 shrink-0 overflow-hidden rounded-md transition-shadow duration-300">
    <img id="sw-art" crossorigin="anonymous" src="" alt="Album cover" class="size-full object-cover" />
  </div>
  <!-- Track Info -->
  <div class="flex min-w-0 flex-1 flex-col justify-center leading-tight">
    <h4 id="sw-track" class="truncate pr-6 font-semibold tracking-tight text-white"></h4>

    <p id="sw-artist" class="truncate pr-6 text-xs font-medium text-white/80"></p>

    <!-- Bottom row: album truncates against invite link -->
    <div class="mt-1 flex items-center gap-2">
      <p id="sw-album" class="min-w-0 truncate text-xs text-white/60"></p>

      <a
        id="sw-link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="group/link ml-auto flex shrink-0 items-center gap-1 text-xs text-white/70 transition-colors hover:text-white">
        <span id="sw-invite"></span>

        <span class="inline-block transition-transform group-hover/link:translate-x-0.5">
          <IconArrowRight class="size-3" />
        </span>
      </a>
    </div>
  </div>
  <IconSpotify class="absolute top-2 right-2 size-4 text-(--light-color)/40" />
</div>

<script>
  import { extractGradientColors, fallbackGradient } from "../utils/extract-color"

  const POLL_INTERVAL_MS = 30_000

  const FEATURED_TRACK = {
    trackName: "Niagara Falls",
    artistName: "The Weeknd",
    albumName: "Hurry Up Tomorrow",
    trackUrl: "https://open.spotify.com/track/2v0AG62ZHtD3I4YmTb3WYM",
    labelText: "On repeat",
    invite: "Listen now",
    artUrl: "https://i.scdn.co/image/ab67616d00001e02982320da137d0de34410df61",
    ...fallbackGradient
  } as const

  // Iris dark palette — used when art fails to load and there is no album color to extract
  const ERROR_GRADIENT = {
    top: "#262a65", // iris-dark-4
    bottom: "#171625", // iris-dark-2
    glow: "#5b5bd6", // iris-dark-9
    light: "#a5a8f3" // iris-dark-11
  } as const

  const card = document.getElementById("sw-card") as HTMLElement
  const artWrap = document.getElementById("sw-art-wrap") as HTMLElement
  const art = document.getElementById("sw-art") as HTMLImageElement
  const track = document.getElementById("sw-track") as HTMLElement
  const artist = document.getElementById("sw-artist") as HTMLElement
  const album = document.getElementById("sw-album") as HTMLElement
  const link = document.getElementById("sw-link") as HTMLAnchorElement
  const invite = document.getElementById("sw-invite") as HTMLElement

  function setInvite(cardText: string, labelText: string) {
    invite.textContent = cardText
    const footerLabel = document.getElementById("sw-footer-label")
    if (footerLabel) footerLabel.textContent = labelText
  }

  function applyGradient(colors: { top: string; bottom: string; glow: string; light: string }) {
    card.style.background = `linear-gradient(135deg, ${colors.top}, ${colors.bottom})`
    card.style.setProperty("--glow-color", colors.glow)
    card.style.setProperty("--light-color", colors.light)
  }

  function applyErrorGradient() {
    card.style.background = `linear-gradient(135deg, ${ERROR_GRADIENT.top}, ${ERROR_GRADIENT.bottom})`
    card.style.setProperty("--glow-color", ERROR_GRADIENT.glow)
    card.style.setProperty("--light-color", ERROR_GRADIENT.light)
  }

  function applyFeaturedTrack() {
    track.textContent = FEATURED_TRACK.trackName
    artist.textContent = FEATURED_TRACK.artistName
    album.textContent = FEATURED_TRACK.albumName
    link.href = FEATURED_TRACK.trackUrl
    setInvite(FEATURED_TRACK.invite, FEATURED_TRACK.labelText)
    artWrap.classList.remove("hidden")
    art.src = FEATURED_TRACK.artUrl
    applyGradient(fallbackGradient)
  }

  async function fetchAndRender() {
    try {
      const res = await fetch("/api/spotify/now-playing")
      const data = await res.json()

      if (data.error) {
        applyFeaturedTrack()
        return
      }

      track.textContent = data.trackName
      artist.textContent = data.artistName
      album.textContent = data.albumName
      link.href = data.trackUrl
      setInvite(data.isPlaying ? "listen along" : "Listen now", data.isPlaying ? "Now playing" : "Last played")

      const proxiedUrl = `/api/spotify/artwork?url=${encodeURIComponent(data.albumArtUrl)}`

      if (art.src !== proxiedUrl) {
        art.onload = async () => {
          const colors = await extractGradientColors(art)
          applyGradient(colors)
        }
        art.onerror = () => {
          artWrap.classList.add("hidden")
          applyErrorGradient()
        }
        art.src = proxiedUrl
      }
      artWrap.classList.remove("hidden")
    } catch {
      applyFeaturedTrack()
    }
  }

  applyFeaturedTrack()
  fetchAndRender()
  setInterval(fetchAndRender, POLL_INTERVAL_MS)
</script>
