---
import IconCopy from "../assets/icons/copy.svg"
import IconCheck from "../assets/icons/check.svg"
import IconLinkedin from "../assets/icons/linkedin.svg"
---

<section id="outro" class="px-4 py-16 sm:px-6 sm:py-24">
  <div class="mx-auto w-full max-w-5xl">
    <h2
      class="font-display text-display mb-4 text-2xl leading-tight font-medium sm:text-3xl md:text-4xl lg:text-5xl">
      <span class="block">If you've made it this far,</span>
      <span class="block">we've basically been introduced.</span>
    </h2>
    <div class="text-foreground mb-8 leading-relaxed sm:mb-12 sm:text-lg">
      <p>I'm looking for the right team to grow with</p>
      <p>somewhere I can contribute, learn fast, and build things that matter.</p>
      <p>If that sounds like your team, I'd love to hear from you.</p>
    </div>
    <div
      class="flex flex-col gap-4 text-lg font-medium sm:flex-row sm:gap-6 md:text-xl lg:text-2xl">
      <button
        id="copy-email-btn"
        class="text-foreground hover:text-muted inline-flex w-fit cursor-pointer items-center gap-2 transition-colors duration-200">
        <span id="copy-icon"><IconCopy class="size-5 md:size-6" /></span>
        <span id="check-icon" class="hidden"
          ><IconCheck class="text-accent size-5 md:size-6" /></span
        >
        <span id="email-label">hi@ahmadghoniem.me</span>
      </button>

      <a
        href="https://www.linkedin.com/in/ahmad-ghoniem/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground hover:text-muted inline-flex w-fit items-center gap-2 transition-colors duration-200">
        <IconLinkedin class="size-5 md:size-6" />
        <span>Connect on LinkedIn</span>
      </a>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("copy-email-btn")
  const copyIcon = document.getElementById("copy-icon")
  const checkIcon = document.getElementById("check-icon")

  if (btn && copyIcon && checkIcon) {
    btn.addEventListener("click", async () => {
      await navigator.clipboard.writeText("hi@ahmadghoniem.me")
      copyIcon.classList.add("hidden")
      checkIcon.classList.remove("hidden")
      setTimeout(() => {
        copyIcon.classList.remove("hidden")
        checkIcon.classList.add("hidden")
      }, 2000)
    })
  }
</script>
