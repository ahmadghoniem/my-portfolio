---
import IconReact from "../assets/icons/react.svg"
import IconTs from "../assets/icons/typescript.svg"
import IconTailwindcss from "../assets/icons/tailwindcss.svg"
import IconChrome from "../assets/icons/chrome.svg"
import IconHardhat from "../assets/icons/hardhat.svg"
import IconRainbowKit from "../assets/icons/rainbowkit.svg"
import IconSanity from "../assets/icons/sanity.svg"
import IconSocketIO from "../assets/icons/socketio.svg"
import IconSupabase from "../assets/icons/supabase.svg"
import IconViem from "../assets/icons/viem.svg"
import IconWagmi from "../assets/icons/wagmi.svg"
import IconRecharts from "../assets/icons/recharts.svg"
import IconAstro from "../assets/icons/astro.svg"
import IconNodejs from "../assets/icons/nodejs.svg"
import IconShadcn from "../assets/icons/shadcn.svg"
import IconSerialport from "../assets/icons/serialport.svg"
import IconLexical from "../assets/icons/lexical.svg"
import zustandLogo from "../assets/images/tech/zustand.png"

interface Props {
  tag: string
}

const { tag } = Astro.props
const normalized = tag.toLowerCase()

type ComponentEntry = { type: "component"; icon: any }
type ImageEntry = { type: "image"; src: string }
type IconEntry = ComponentEntry | ImageEntry

const iconMap: Record<string, IconEntry> = {
  react: { type: "component", icon: IconReact },
  typescript: { type: "component", icon: IconTs },
  tailwind: { type: "component", icon: IconTailwindcss },
  chrome: { type: "component", icon: IconChrome },
  hardhat: { type: "component", icon: IconHardhat },
  rainbowkit: { type: "component", icon: IconRainbowKit },
  sanity: { type: "component", icon: IconSanity },
  socket: { type: "component", icon: IconSocketIO },
  supabase: { type: "component", icon: IconSupabase },
  viem: { type: "component", icon: IconViem },
  wagmi: { type: "component", icon: IconWagmi },
  recharts: { type: "component", icon: IconRecharts },
  astro: { type: "component", icon: IconAstro },
  serialport: { type: "component", icon: IconSerialport },
  node: { type: "component", icon: IconNodejs },
  shadcn: { type: "component", icon: IconShadcn },
  lexical: { type: "component", icon: IconLexical },
  zustand: { type: "image", src: zustandLogo.src }
}

const key = Object.keys(iconMap).find((k) => normalized.includes(k))
const match = key ? iconMap[key] : null
---

<span
  class="border-border text-foreground inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-sm sm:px-3 sm:py-1"
  class:list={[{ "pl-1.5": !!match }]}>
  {match?.type === "component" && <match.icon class="size-4 shrink-0" />}
  {
    match?.type === "image" && (
      <img src={match.src} alt="" class="size-4 shrink-0 object-contain" aria-hidden="true" />
    )
  }
  <span>{tag}</span>
</span>
