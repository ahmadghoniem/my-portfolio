---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import IconArrowRight from "../assets/icons/arrow-right.svg"
import IconArrowUpRight from "../assets/icons/arrow-up-right.svg"

type CardColor = "violet" | "slate" | "sky" | "yellow"

interface Props {
  title: string
  description: string
  tags: string[]
  image?: string
  cardColor?: CardColor
  quote?: string
  citation?: string
  ctas?: { label: string; href: string }[]
  slug?: string
}

const { title, description, tags, image, cardColor, quote, citation, ctas, slug } = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/projects/*/*", {
  eager: true
})
const resolvedImage =
  image && slug ? images[`/src/assets/projects/${slug}/${image}`]?.default : undefined

const builtWith = new Intl.ListFormat("en", { style: "long", type: "conjunction" }).format(tags)

const style = cardColor
  ? `background-color: var(--card-${cardColor}-bg); --shadow-color: var(--card-${cardColor}-shadow); --card-border-color: var(--${cardColor}-7);`
  : undefined

type ResolvedCta = { label: string; href: string; isInternal: boolean; linkClass: string }
const resolvedCtas: ResolvedCta[] = (ctas ?? []).map((cta) => ({
  ...cta,
  isInternal: cta.href.startsWith("/"),
  linkClass: cta.href.startsWith("/") ? "link-internal" : "link-external"
}))
---

<article
  class="relative flex w-full flex-col overflow-hidden rounded-2xl shadow-sm transition-shadow duration-200 ease-out hover:shadow-md lg:h-96 lg:flex-row"
  style={style}
  data-card={cardColor}>
  <!-- Left: text -->
  <div class="flex flex-1 flex-col justify-between p-4 md:p-6 md:pb-4 lg:p-6">
    <div>
      <h3 class="font-display text-2xl font-semibold sm:text-3xl lg:text-4xl">
        {title}
      </h3>
      <p class="mt-2 max-w-md text-sm/relaxed sm:text-base lg:mt-3">
        {description}
      </p>

      {
        quote && (
          <blockquote
            class="border-border mt-3 border-l-2 pl-4 lg:mt-4"
            style="border-color: var(--card-border-color, var(--color-border));">
            <p class="text-muted text-xs/relaxed sm:text-sm">&ldquo;{quote}&rdquo;</p>
            {citation && (
              <cite class="text-tertiary mt-1.5 block text-xs not-italic">&mdash; {citation}</cite>
            )}
          </blockquote>
        )
      }
    </div>

    <!-- Bottom: built with + CTAs at < md and lg+ -->
    <div class="mt-4 lg:mt-0">
      <p class="text-muted text-xs sm:text-sm">
        <span class="text-foreground font-medium">Built with</span>
        {builtWith}
      </p>

      {
        resolvedCtas.length > 0 && (
          <div class="mt-3 flex items-center gap-6 md:hidden lg:mt-4 lg:flex">
            {resolvedCtas.map((cta) => (
              <a
                href={cta.href}
                class={`${cta.linkClass} text-sm sm:text-base`}
                {...(!cta.isInternal && { target: "_blank", rel: "noopener noreferrer" })}>
                {cta.label}
                <span class="arrow">
                  {cta.isInternal ? (
                    <IconArrowRight class="inline-block size-3.5 sm:size-4" />
                  ) : (
                    <IconArrowUpRight class="inline-block size-3.5 sm:size-4" />
                  )}
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <!-- CTAs absolutely positioned ” md to lg only -->
  {
    resolvedCtas.length > 0 && (
      <div class="absolute top-6 right-6 hidden flex-row items-center gap-4 md:flex lg:hidden">
        {resolvedCtas.map((cta) => (
          <a
            href={cta.href}
            class={`${cta.linkClass} text-sm sm:text-base`}
            {...(!cta.isInternal && { target: "_blank", rel: "noopener noreferrer" })}>
            {cta.label}
            <span class="arrow">
              {cta.isInternal ? (
                <IconArrowRight class="inline-block size-3.5 sm:size-4" />
              ) : (
                <IconArrowUpRight class="inline-block size-3.5 sm:size-4" />
              )}
            </span>
          </a>
        ))}
      </div>
    )
  }

  <!-- Right: image -->
  {
    resolvedImage && (
      <div class="hidden max-h-96 justify-end pl-4 md:flex lg:max-h-none lg:w-xl lg:py-3 lg:pr-3 lg:pl-0">
        <Image
          src={resolvedImage}
          alt={title}
          class="size-full rounded-xl object-cover object-top-left shadow-[-15px_15px_40px_-10px_var(--shadow-color)]"
        />
      </div>
    )
  }
</article>
